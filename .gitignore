/srv.exe.old*
*.test
*.out

# srv-mcp-dev.cmd build output (the wrapper script itself IS committed)
/build.log

# goreleaser local-snapshot output
/dist/

# Tool caches (Claude Code workspace, local go build cache)
.claude/
.gocache/

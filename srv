#!/usr/bin/env bash
# POSIX shim -- copy this file (or symlink it) to a directory on PATH.
# Resolves through symlinks so `ln -s /path/to/srv ~/.local/bin/srv` works.
SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -L "$SOURCE" ]; do
    LINK_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$LINK_DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
exec python3 "$DIR/src/srv.py" "$@"
